# Béa — Production Environment Template
# 
# ⚠️  THIS IS A TEMPLATE ONLY. Every value marked CHANGE_ME must be generated
#     before use. Do NOT copy this file as-is to a production server.
#
# Generate secrets:
#   BEA_SECRET_KEY:      openssl rand -hex 32
#   BEA_API_TOKEN:       python3 -c "import secrets; print(secrets.token_urlsafe(40))"
#   BEA_ADMIN_PASSWORD:  openssl rand -base64 24
#   POSTGRES_PASSWORD:   openssl rand -hex 32
#   REDIS_PASSWORD:      openssl rand -hex 32
#
# ⚠️  NEVER commit a filled .env to git.
# ⚠️  NEVER use CORS wildcard (*) in production.

# ================================================================
# PRODUCTION ENVIRONMENT
# ================================================================
BEA_PRODUCTION=true
DRY_RUN=false

# ── Secrets (ALL must be generated — never use placeholders) ───
BEA_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32  # pragma: allowlist secret
BEA_API_TOKEN=CHANGE_ME_GENERATE_WITH_python_secrets_token_urlsafe  # pragma: allowlist secret
BEA_ADMIN_PASSWORD=CHANGE_ME_GENERATE_STRONG_PASSWORD  # pragma: allowlist secret
POSTGRES_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32  # pragma: allowlist secret
REDIS_PASSWORD=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32  # pragma: allowlist secret

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://your-db-host:5432/beamax
REDIS_URL=redis://your-redis-host:6379/0
POSTGRES_USER=bea
POSTGRES_DB=beamax

# ── LLM Provider ───────────────────────────────────────────────
# At least one provider must be configured with a real key.
OPENROUTER_API_KEY=CHANGE_ME_REAL_OPENROUTER_KEY  # pragma: allowlist secret
OPENROUTER_MODEL_FAST=openai/gpt-oss-20b:free
OPENROUTER_MODEL_STANDARD=openai/gpt-oss-20b:free
OPENROUTER_MODEL_STRONG=openai/gpt-oss-120b:free

# ── Vector Memory (Qdrant) ─────────────────────────────────────
QDRANT_URL=https://your-qdrant-host:6333
QDRANT_API_KEY=CHANGE_ME_REAL_QDRANT_KEY  # pragma: allowlist secret

# ── API Config ─────────────────────────────────────────────────
BEA_API_URL=https://your-domain.example
BEA_USE_COGNITION=1

# CORS: MUST be explicit origins. NEVER use * in production.
BEA_CORS_ORIGINS=https://your-domain.example

# Rate-limiting: MUST be enabled in production.
BEA_RATE_LIMIT_ENABLED=true
BEA_RATE_LIMIT_PER_MINUTE=60

# ── Self-improvement (MUST stay disabled unless supervised) ────
# BEA_CONTINUOUS_IMPROVEMENT=0
# BEA_SKIP_IMPROVEMENT_GATE=    # DANGER: bypass total — NEVER set in production

# ── Optional integrations ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Docker images ──────────────────────────────────────────────
QDRANT_IMAGE=qdrant/qdrant:v1.9.7
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

# ── Misc ───────────────────────────────────────────────────────
BEA_IMPROVEMENT_MODE=propose
BEA_FTS_DB=workspace/memory_fts.db
RESOURCE_MAX_AGENTS=8
