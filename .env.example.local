# Béa — Local Development Environment
# Copy to .env for local development:  cp .env.example.local .env
# NEVER commit .env to git.
# Generate tokens: python3 -c "import secrets; print(secrets.token_urlsafe(40))"
# Generate secrets: openssl rand -hex 32

# ================================================================
# LOCAL DEVELOPMENT ONLY — NOT FOR PRODUCTION
# ================================================================
BEA_PRODUCTION=false
DRY_RUN=true

# ── Secrets (generate your own, do NOT use these placeholders) ──
BEA_SECRET_KEY=local-dev-only-generate-with-openssl-rand-hex-32  # pragma: allowlist secret
BEA_API_TOKEN=local-dev-only-generate-with-python-secrets-token-urlsafe  # pragma: allowlist secret
BEA_ADMIN_PASSWORD=local-dev-only-strong-password  # pragma: allowlist secret

# ── Database (Docker) ──────────────────────────────────────────
DATABASE_URL=postgresql://127.0.0.1:5432/beamax
REDIS_URL=redis://127.0.0.1:6379/0
POSTGRES_USER=bea
POSTGRES_DB=beamax
POSTGRES_PASSWORD=local-dev  # pragma: allowlist secret

# ── LLM Provider (pick one) ────────────────────────────────────
# OpenRouter (free tier sufficient for testing)
OPENROUTER_API_KEY=your-key-here  # pragma: allowlist secret
OPENROUTER_MODEL_FAST=openai/gpt-oss-20b:free
OPENROUTER_MODEL_STANDARD=openai/gpt-oss-20b:free
OPENROUTER_MODEL_STRONG=openai/gpt-oss-120b:free

# Ollama (optional local fallback)
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL_MAIN=gemma4:12b
OLLAMA_MODEL_FAST=gemma4:12b
OLLAMA_MODEL_CODE=gemma4:12b
OLLAMA_DEFAULT_MODEL=tinyllama

# ── Vector Memory (Qdrant) ─────────────────────────────────────
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=

# ── API Config ─────────────────────────────────────────────────
BEA_API_URL=http://127.0.0.1:8000
BEA_USE_COGNITION=1

# CORS: localhost only for dev. NEVER use * in production.
BEA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate-limiting (enabled by default, lower for dev convenience)
BEA_RATE_LIMIT_ENABLED=true
BEA_RATE_LIMIT_PER_MINUTE=120

# ── Self-improvement (DISABLED by default — never enable without supervision) ──
# BEA_CONTINUOUS_IMPROVEMENT=0
# BEA_SKIP_IMPROVEMENT_GATE=    # DANGER: bypass total — never set in any environment

# ── Optional integrations (leave empty if unused) ──────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

# ── Docker images ──────────────────────────────────────────────
QDRANT_IMAGE=qdrant/qdrant:v1.9.7
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
OLLAMA_IMAGE=ollama/ollama:0.6.2

# ── Misc ───────────────────────────────────────────────────────
BEA_IMPROVEMENT_MODE=propose
BEA_FTS_DB=workspace/memory_fts.db
RESOURCE_MAX_AGENTS=8
