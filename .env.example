# BeaMax Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# Generate API token: python3 -c "import secrets; print(secrets.token_urlsafe(40))"
# Generate JWT secret: openssl rand -hex 32

# ================================================================
# BEAMAX PRODUCTION ENVIRONMENT - SECURED
# Secrets générés avec openssl rand -hex 32
# Ne JAMAIS commiter ce fichier

# ── Secrets PostgreSQL — générer avec: openssl rand -hex 32 ───
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_32

# ── Secrets N8N — générer avec: openssl rand -hex 32 ──────────
N8N_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ── N8N Auth ──────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_strong_password

# ── Domain Configuration ────────────────────────────────────────
# Remplacer par votre domaine pour activer TLS auto
N8N_DOMAIN=77.42.40.146

# NOTES:
# - POSTGRES_PASSWORD: Nouveau secret fort (32 bytes hex)
# - N8N_ENCRYPTION_KEY: Nouveau secret fort (32 bytes hex)
# - Les anciens secrets (testn8nkey12345678901234567890) sont ROTÉS
# - Configurer N8N_DOMAIN avec un vrai domaine pour Let's Encrypt
REDIS_PASSWORD=CHANGE_ME_openssl_rand_hex_32
BEA_SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
DRY_RUN=true

# LLM
MODEL_STRATEGY=openrouter
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY
ORCHESTRATOR_MODEL=qwen/qwen3-32b
OLLAMA_HOST=http://172.20.0.4:11434

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=YOUR_QDRANT_KEY

# Postgres
DATABASE_URL=postgresql://bea:CHANGE_ME_openssl_rand_hex_32@postgres:5432/beamax
POSTGRES_HOST=postgres
POSTGRES_USER=bea
POSTGRES_DB=beamax
BEA_API_TOKEN=jv-CHANGE_ME
OLLAMA_MODEL=tinyllama
OLLAMA_DEFAULT_MODEL=tinyllama

# Ollama models — tinyllama fallback uniquement (prod = OpenRouter)
OLLAMA_MODEL_MAIN=tinyllama
OLLAMA_MODEL_CODE=tinyllama
OLLAMA_MODEL_FAST=tinyllama
OLLAMA_MODEL_VISION=tinyllama
OLLAMA_MODEL_UNCENSORED=tinyllama

# OpenRouter — models prod
OPENROUTER_MODEL_FAST=google/gemini-2.0-flash-001
OPENROUTER_MODEL_STANDARD=anthropic/claude-3.5-haiku
OPENROUTER_MODEL_STRONG=qwen/qwen3-32b
ARCHITECT_MODEL=anthropic/claude-3.5-haiku
CODER_MODEL=qwen/qwen-2.5-coder-32b-instruct
BEA_PRODUCTION=true
