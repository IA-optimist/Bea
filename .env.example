# JarvisMax OS — Environment Configuration

# ============================================================================
# DATABASE (PostgreSQL)
# ============================================================================
POSTGRES_USER=jarvismax
POSTGRES_PASSWORD=jarvismax_secret_2026_CHANGE_ME
POSTGRES_DB=jarvismax
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================================================
# CACHE & QUEUE (Redis)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_2026_CHANGE_ME

# ============================================================================
# ENVIRONMENT
# ============================================================================
JARVISMAX_ENV=development  # development, staging, production

# ============================================================================
# API KEYS (Payment Processing)
# ============================================================================
STRIPE_SECRET_KEY=sk_test_xxx  # Get from https://stripe.com
STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ============================================================================
# API KEYS (AI Services)
# ============================================================================
OPENAI_API_KEY=sk-xxx  # Get from https://platform.openai.com
ANTHROPIC_API_KEY=sk-ant-xxx  # Get from https://console.anthropic.com

# ============================================================================
# API KEYS (Deployment)
# ============================================================================
VERCEL_TOKEN=xxx  # Get from https://vercel.com/account/tokens
RAILWAY_TOKEN=xxx  # Get from https://railway.app/account/tokens
GITHUB_TOKEN=ghp_xxx  # Get from https://github.com/settings/tokens

# ============================================================================
# API KEYS (Security / HexStrike)
# ============================================================================
HACKERONE_API_KEY=xxx  # Get from https://hackerone.com
BUGCROWD_API_KEY=xxx  # Get from https://bugcrowd.com

# ============================================================================
# API KEYS (SOC Service)
# ============================================================================
WAZUH_API_URL=https://your-wazuh-server:55000
WAZUH_API_USER=admin
WAZUH_API_PASSWORD=xxx

# ============================================================================
# SECURITY
# ============================================================================
JWT_SECRET_KEY=your_jwt_secret_key_here_CHANGE_ME
ENCRYPTION_KEY=your_encryption_key_here_CHANGE_ME

# ============================================================================
# MONITORING (Optional)
# ============================================================================
SENTRY_DSN=https://xxx@sentry.io/xxx  # Optional: Error tracking
PROMETHEUS_ENABLED=true

# ============================================================================
# TELEGRAM (Optional)
# ============================================================================
TELEGRAM_BOT_TOKEN=xxx  # Get from @BotFather
TELEGRAM_CHAT_ID=xxx

# ============================================================================
# EMAILS (Optional)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=noreply@jarvismax.ai
