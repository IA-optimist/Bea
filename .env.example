# BeaMax Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# Generate API token: python3 -c "import secrets; print(secrets.token_urlsafe(40))"
# Generate JWT secret: openssl rand -hex 32
#
# Templates:
#   .env.example.local      — local dev defaults (Docker stack, no auth required)
#   .env.example.production — production hardened config (TLS, strong secrets, rate-limit)

# ================================================================
# BEAMAX PRODUCTION ENVIRONMENT - SECURED
# Secrets générés avec openssl rand -hex 32
# Ne JAMAIS committer ce fichier

# ── Secrets PostgreSQL — générer avec: openssl rand -hex 32 ───
POSTGRES_PASSWORD=CHANGE_ME_openssl_rand_hex_32

# ── Secrets N8N — générer avec: openssl rand -hex 32 ──────────
N8N_ENCRYPTION_KEY=CHANGE_ME_openssl_rand_hex_32

# ── N8N Auth ──────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME_strong_password

# ── Domain Configuration ───────────────────────────────────────
# Remplacer par votre domaine pour activer TLS auto
N8N_DOMAIN=77.42.40.146

# NOTES:
# - POSTGRES_PASSWORD: Nouveau secret fort (32 bytes hex)
# - N8N_ENCRYPTION_KEY: Nouveau secret fort (32 bytes hex)
# - Les anciens secrets (testn8nkey12345678901234567890) sont ROTÉS
# - Configurer N8N_DOMAIN avec un vrai domaine pour Let's Encrypt
REDIS_PASSWORD=CHANGE_ME_openssl_rand_hex_32
BEA_SECRET_KEY=GENERATE_WITH_openssl_rand_hex_32
DRY_RUN=true

# ── Béa local runtime (configuration principale actuelle) ─────
# Béa lit os.environ DIRECTEMENT (pas de load_dotenv). En venv local, exporter ces vars :
#     set -a; source .env; set +a    (bash)
# (En Docker compose, .env est chargé automatiquement.)

# ── Workers = Bea v3.1 servie par Ollama (local venv -> 127.0.0.1) ──
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL_MAIN=gemma4:12b
OLLAMA_MODEL_FAST=gemma4:12b
OLLAMA_MODEL_CODE=gemma4:12b
OLLAMA_DEFAULT_MODEL=tinyllama

# ── Cerveau Codex = backend ChatGPT direct ──
CODEX_MODEL=gpt-5.5

# ── Telegram (pilotage dev/test de Béa) ──
TELEGRAM_BOT_TOKEN=REPLACE_ME
TELEGRAM_ALLOWED_USERS=REPLACE_ME

# OpenRouter (cerveau agent fallback)
OPENROUTER_API_KEY=REPLACE_ME
OPENROUTER_MODEL_FAST=openai/gpt-oss-20b:free
OPENROUTER_MODEL_STANDARD=openai/gpt-oss-20b:free
OPENROUTER_MODEL_STRONG=openai/gpt-oss-120b:free
ORCHESTRATOR_MODEL=openai/gpt-oss-120b:free
ARCHITECT_MODEL=openai/gpt-oss-20b:free
CODER_MODEL=openai/gpt-oss-20b:free

# Qdrant
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=REPLACE_ME

# Agent complet (cognition)
BEA_API_URL=http://127.0.0.1:8000
BEA_API_TOKEN=REPLACE_ME
BEA_USE_COGNITION=1
BEA_ADMIN_PASSWORD=REPLACE_ME
BEA_PRODUCTION=true

# Docker stack PG
POSTGRES_USER=bea
POSTGRES_DB=beamax
DATABASE_URL=postgresql://bea:CHANGE_ME_openssl_rand_hex_32@127.0.0.1:5432/beamax

# Docker images
QDRANT_IMAGE=qdrant/qdrant:v1.9.7
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine
OLLAMA_IMAGE=ollama/ollama:0.6.2
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=

RESOURCE_MAX_AGENTS=8

# Auto-amélioration
BEA_IMPROVEMENT_MODE=propose
BEA_FTS_DB=workspace/memory_fts.db

# ── API hardening (ajouté 0.1.0-dev-preview) ─────────────────
# CORS : liste d'origines autorisees (separees par virgule)
# Le wildcard '*' est BLOQUE quand allow_credentials=True.
# Laisser vide = defaut localhost uniquement (dev local).
BEA_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate-limiting (slowapi)
BEA_RATE_LIMIT_ENABLED=true
BEA_RATE_LIMIT_PER_MINUTE=60

# ── Self-improvement gates ────────────────────────────────────
# Desactive par defaut. Ne pas activer sans supervision humaine.
# BEA_CONTINUOUS_IMPROVEMENT=1
# BEA_SKIP_IMPROVEMENT_GATE=    # DANGER : bypass total -- ne jamais mettre en prod
