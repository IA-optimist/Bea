{
  "manifest_version": "1.0",
  "tool_id": "filesystem:write",
  "name": "Filesystem Write",
  "description": "Write or modify files within allowed paths",
  "version": "1.0.0",
  "author": "Bea Team",
  "permissions": [
    {
      "resource_type": "filesystem",
      "scope": "write",
      "allowed_patterns": [
        "workspace/**",
        "data/**"
      ],
      "denied_patterns": [
        "/etc/**",
        "/sys/**",
        "/proc/**",
        "*.exe",
        "*.dll"
      ],
      "requires_approval": true
    }
  ],
  "risk_level": "medium",
  "requires_secrets": [],
  "requires_network": false,
  "requires_approval": true,
  "dangerous_actions": [
    "overwrite_system_file",
    "delete_critical_file"
  ],
  "signature": "sha256:99dce8f61de7d1167f6c6747c18e25d881a4260d5d25bc36fe972f00ff78a8c8",
  "created_at": "2026-06-19T00:00:00Z"
}