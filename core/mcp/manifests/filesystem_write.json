{
  "manifest_version": "1.0",
  "tool_id": "filesystem:write",
  "name": "Filesystem Write",
  "description": "Write or modify files within allowed paths",
  "version": "1.0.0",
  "author": "Bea Team",
  "permissions": [
    {
      "resource_type": "filesystem",
