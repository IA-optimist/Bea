{
  "manifest_version": "1.0",
  "tool_id": "shell:execute",
  "name": "Shell Execute",
  "description": "Execute a small set of read-only git and test commands",
  "version": "1.0.0",
  "author": "Bea Team",
  "permissions": [
    {
      "resource_type": "system",
      "scope": "execute",
      "allowed_patterns": [
        "git status *",
        "git diff *",
        "git log *",
        "python -m pytest *"
      ],
      "denied_patterns": [
        "rm *",
        "sudo *",
        "chmod 777 *",
        "eval *",
        "exec *",
        "curl *",
        "wget *",
        "bash *",
        "sh *",
        ">*",
        "|*"
      ],
      "requires_approval": true
    }
  ],
  "risk_level": "high",
  "requires_secrets": [],
  "requires_network": false,
  "requires_approval": false,
  "dangerous_actions": [
    "destructive_command",
    "privilege_escalation"
  ],
  "signature": "hmac-sha256:d3aa60627b95910edd8decb154fedccfcb5f68e945bb3f5b574a44e16898a3a2",
  "created_at": "2026-06-19T13:01:12.017789"
}
