{
    # Disable automatic HTTPS (use self-signed for now)
    auto_https off
}

# Local development
jarvismax.local {
    handle /app/* {
        reverse_proxy frontend:3000
    }
    handle /api/* {
        reverse_proxy api:8000
    }
    handle /ws/* {
        reverse_proxy api:8000
    }
    handle {
        reverse_proxy frontend:3000
    }
}

# Production domain (HTTP only for testing)
http://jarvis.jarvismaxapp.co.uk {
    # API
    handle /api/* {
        reverse_proxy jarvis_core:8000
    }

    # WebSocket
    handle /ws/* {
        reverse_proxy jarvis_core:8000
    }

    # Frontend
    handle /app/* {
        reverse_proxy frontend:3000
    }

    # Default to API docs
    handle {
        redir /docs permanent
    }
}
