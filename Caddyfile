{
    http_port 8080
    auto_https off
}

jarvis.jarvismaxapp.co.uk {
    handle /api/* {
        reverse_proxy jarvismax-api:8000
    }
    handle /ws/* {
        reverse_proxy jarvismax-api:8000
    }
    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }
}

:8080 {
    handle /api/* {
        reverse_proxy jarvismax-api:8000
    }
    handle {
        root * /srv/frontend
        try_files {path} /index.html
        file_server
    }
}
