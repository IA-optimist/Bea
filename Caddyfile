jarvismax.local {
    # Frontend
    handle /app/* {
        reverse_proxy frontend:3000
    }

    # API
    handle /api/* {
        reverse_proxy api:8000
    }

    # WebSocket
    handle /ws/* {
        reverse_proxy api:8000
    }

    # Default to frontend
    handle {
        reverse_proxy frontend:3000
    }
}
